# ──────────────────────────────────────────────────────────────────────────────
# Secure Financial Pipeline — environment variable template
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Slack incoming webhook URL for failure alerting
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Airflow metadata database connection
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Airflow core settings
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here-generate-with-python-cryptography
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-key-here

# Pipeline paths (defaults work inside Docker; override for local dev)
PIPELINE_DATA_DIR=/opt/airflow/data
PIPELINE_DELTA_DIR=/opt/airflow/data/delta

# PySpark tuning
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
